{
  "name": "focus",
  "version": "1.0.0",
  "description": "Gamified todo app",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron_config_cache=.electron-cache vite",
    "start": "electron_config_cache=.electron-cache ./node_modules/.bin/electron dist-electron/main.js",
    "build": "vite build",
    "dist": "vite build && electron-builder --mac",
    "dist:win": "vite build && electron-builder --win",
    "dist:all": "vite build && electron-builder --mac --win",
    "postinstall": "electron_config_cache=.electron-cache node node_modules/electron/install.js || true && electron-builder install-app-deps || true"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^12.6.2",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "appId": "com.focus.app",
    "productName": "Focus",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "darkModeSupport": true,
      "minimumSystemVersion": "12.0"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "installerIcon": null,
      "uninstallerIcon": null,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "npmRebuild": true
  }
}
